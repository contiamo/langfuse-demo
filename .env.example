# Database (matches docker-compose defaults)
DATABASE_URL=postgresql://ragdemo:ragdemo@localhost:55432/ragdemo

# LLM — any model string litellm supports (e.g. bedrock/anthropic.claude-3-sonnet-...)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# Retrieval
RETRIEVAL_TOP_K=5          # number of chunks passed to the LLM
RETRIEVAL_MIN_SIMILARITY=0.0  # cosine similarity threshold (0.0 = off, 0.75 = strict)

# Langfuse (leave empty to disable tracing)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
